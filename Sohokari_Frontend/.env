EXPO_PUBLIC_API_BASE_URL=https://sohokari-backend.onrender.com
EXPO_PUBLIC_WS_URL=wss://sohokari-backend.onrender.com/ws
# For Android Emulator:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080
# EXPO_PUBLIC_WS_URL=ws://10.0.2.2:8080/ws

# For iOS Simulator / Web, comment out above and use:
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
# EXPO_PUBLIC_WS_URL=ws://localhost:8080/ws

# For a Physical Device, use your computer's local IP (e.g. 192.168.1.X):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.31.114:8080
# EXPO_PUBLIC_WS_URL=ws://192.168.31.114:8080/ws